{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "ignorePatterns": [
    "dist",
    "dist-ssr",
    "build",
    "coverage",
    ".pnpm-store",
    ".pnpm",
    ".oxfmtrc.json",
    ".skip.config.json",
    "components.json",
    ".oxlintrc.json",
    "index.html",
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "postcss.config.js",
    "README.md",
    "tests/",
    "tsconfig.*",
    "vite.config.ts",
    "logs",
    "*.log",
    "npm-debug.log*",
    "yarn-debug.log*",
    "yarn-error.log*",
    "pnpm-debug.log*",
    "lerna-debug.log*",
    "node_modules",
    "dev-dist",
    "dev-dist-ssr",
    "*.local",
    "*.bak-*",
    "*.legacy-bak-*",
    "*.failed-*",
    "*.tmp",
    ".vscode/*",
    ".idea",
    ".DS_Store",
    "*.suo",
    "*.ntvs*",
    "*.njsproj",
    "*.sln",
    "*.sw?",
    "screenshot.png",
    ".eslintcache",
    ".oxlintcache",
    ".env*",
    "core.[0-9]*"
  ]
}
